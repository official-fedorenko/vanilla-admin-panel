# Server
PORT=3080

# Optional: Enable verbose request logging
# DEBUG=true

# Set to true only if the server runs behind a reverse proxy that terminates
# HTTPS and forwards X-Forwarded-Proto. This makes login cookies use the
# Secure flag. Do NOT enable this if the server is reachable directly over
# plain HTTP, as the header can otherwise be spoofed by the client.
# TRUST_PROXY=true

# Optional: restrict admin login to specific IP addresses (comma-separated).
# Leave unset to allow login attempts from any IP. Useful for private/internal
# deployments. The IP is read from the raw socket address unless TRUST_PROXY=true
# (in which case X-Forwarded-For from your reverse proxy is used instead).
# ADMIN_IP_ALLOWLIST=203.0.113.10,203.0.113.11
